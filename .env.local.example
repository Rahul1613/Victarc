NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay Credentials (from your Razorpay Dashboard Settings -> API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxx
RAZORPAY_SECRET=xxxxxx

# Supabase Service Role Key (from Supabase Project Settings -> API -> service_role key)
# Required to securely bypass Row Level Security (RLS) to upgrade user plans upon payment validation
SUPABASE_SERVICE_ROLE_KEY=xxxxxx

# Admin Quick Approve System Secret Key
ADMIN_SECRET_KEY=xxxxxx_generate_a_long_secret_string
